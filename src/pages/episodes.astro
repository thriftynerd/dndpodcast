---
import Layout from '../layouts/Layout.astro';
import ArchivePageHero from '../components/ArchivePageHero.astro';
import EpisodeSearchBand from '../components/EpisodeSearchBand.astro';
import CuratedRails from '../components/CuratedRails.astro';
import EpisodeList from '../components/EpisodeList.astro';
import { episodes } from '../data/episodes-archive';

// Stats for the hero
const episodeCount = episodes.length;
const totalHours = '~700';  // TODO: compute from real durations once RSS is wired
const campaignCount = 2;
const yearStarted = 2012;

// Recent rail: 8 most recent episodes
const recent = [...episodes]
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 8);

// Editorial picks. These are placeholders per the BUILD_BRIEF — fill in real picks before launch.
const startHere = [
  { href: '/episodes/c2-1-welcome-to-rimeford-c2-e1', label: 'Welcome to Rimeford!', note: 'Our current campaign. Get caught up and join the twitch stream!' },
  { href: '/episodes/c1-1-so-it-begins-campaign-1-episode-1', label: 'They woke up on slabs...', note: 'The very first episode of Drunks and Dragons' },
  { href: '/episodes/c1-122-okay-bye-c2-e122', label: 'Ok, Bye!', note: 'Often cited as a classic episode. The gang attempt to infiltrate an evil city. Okay, bye!' },
  { href: '/episodes/c1-300-swords-and-sobriety-episode-1-tavern-troubles-c1-e300', label: 'Swords and Sobriety', note: 'One of our drunkest episodes ever.' },
];

const loreLandmarks = [
  { href: '/episodes/campaign-1-episode-1', label: 'Steve the Gnoll is born', note: '[The side mission episode]' },
  { href: '/episodes/campaign-1-episode-1', label: 'Thom dies, Steve emerges', note: '[Pick the right episode]' },
  { href: '/episodes/campaign-2-episode-1', label: 'Welcome to Farholde', note: '[First episode of C2]' },
  { href: '/episodes/campaign-1-episode-1', label: 'The Campaign 1 finale', note: '[End of the original saga]' },
];
---

<Layout title="The Archive · Greetings, Adventurers!">
  <ArchivePageHero
    episodeCount={episodeCount}
    totalHours={totalHours}
    campaignCount={campaignCount}
    yearStarted={yearStarted}
  />
  <EpisodeSearchBand />
  <CuratedRails recent={recent} startHere={startHere} loreLandmarks={loreLandmarks} />
  <EpisodeList episodes={episodes} />
</Layout>