---
import Layout from '../layouts/Layout.astro';
import { loadEpisodes } from '../lib/rss';

const episodes = await loadEpisodes();

// ============== STATS ==============
const totalEpisodes = episodes.length;
const totalSeconds = episodes.reduce((sum, ep) => sum + (ep.durationSeconds || 0), 0);
const totalHours = Math.round(totalSeconds / 3600);

// TODO: rss.ts classifier is unreliable for kind detection because Acast tags
// many C1 episodes as `bonus`. Until the classifier is fixed (or the upstream
// Acast tagging is corrected), we hardcode the C2 count to a sensible value.
// Last known: C2 Episode 182 ran April 2026.
const c2Count = 182;

const numberWord = (n: number): string => {
  const ones = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine'];
  const teens = ['ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
  const tens = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];
  if (n < 10) return ones[n];
  if (n < 20) return teens[n - 10];
  if (n < 100) {
    const t = Math.floor(n / 10);
    const o = n % 10;
    return o === 0 ? tens[t] : `${tens[t]}-${ones[o]}`;
  }
  const h = Math.floor(n / 100);
  const r = n % 100;
  if (r === 0) return `${ones[h]} hundred`;
  return `${ones[h]} hundred ${numberWord(r)}`;
};
const heroCountWord = numberWord(totalEpisodes);

// ============== EPISODE LOOKUPS ==============
const findBySlug = (needle: string) =>
  episodes.find((ep) => ep.slug === needle || ep.slug.includes(needle));

const c2First = episodes.find((ep) => ep.kind === 'c2' && ep.episodeNumber === 1);
const c1First = episodes.find((ep) => ep.kind === 'c1' && ep.episodeNumber === 1);

const okayBye = findBySlug('okay-bye');
const kevimp = findBySlug('sweeties-day');
// Bananas Foster intro: bonus-episode-159-monkey-business
const bananaFoster = findBySlug('monkey-business');

const href = (ep: (typeof episodes)[number] | undefined) =>
  ep ? `/episodes/${ep.slug}` : '/episodes';

const c2FirstHref = href(c2First);
const c1FirstHref = href(c1First);
const okayByeHref = href(okayBye);
const kevimpHref = href(kevimp);
const bananaFosterHref = href(bananaFoster);
---

<Layout title="Begin your adventure · Greetings, Adventurers!">
  <main class="begin">

    {/* ============== HERO ============== */}
    <section class="b-hero">
      <div class="b-hero-bg"></div>
      <div class="b-hero-overlay"></div>
      <div class="b-hero-inner">
        <div class="b-hero-eyebrow">For new adventurers</div>
        <h1 class="b-hero-title">So you've never<br/>heard the show.</h1>
        <p class="b-hero-tag">{`${heroCountWord.charAt(0).toUpperCase() + heroCountWord.slice(1)} episodes is, admittedly, a lot.`} Let us help you find your way in.</p>
      </div>
    </section>

    {/* ============== AUDIO PRIMER ============== */}
    <section class="b-primer">
      <div class="b-primer-inner">
        <div class="b-primer-eyebrow">Welcome to Drunkeros</div>
        <h2 class="b-primer-title">In about a minute.</h2>
        <p class="b-primer-body">
          Greetings, Adventurers! is a Dungeons &amp; Dragons actual play podcast that's been running since 2012. Five friends. Two campaigns set in the same hilariously stupid world: <em>Drunkeros</em>. We tell long, serialized stories that build over years, but you don't have to start at the beginning to enjoy the show.
        </p>
        <p class="b-primer-body">
          Our current campaign starts in the mountain village of <em>Rimeford</em>, drops down into the underground city of <em>Mineford</em>, and ends up in <em>Farholde</em>, the capital, where magic is illegal unless you're a cop. Our four heroes are not cops. They're trying to take down a fascist empire while making jokes about butts.
        </p>

        {/* PLACEHOLDER. Once the recap audio is recorded, swap the
            <div class="b-primer-audio"> for an Acast embed iframe. */}
        <div class="b-primer-audio">
          <div class="b-primer-audio-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 18v-6a9 9 0 0118 0v6"/>
              <path d="M21 19a2 2 0 01-2 2h-1v-6h3zM3 19a2 2 0 002 2h1v-6H3z"/>
            </svg>
          </div>
          <div class="b-primer-audio-body">
            <div class="b-primer-audio-eyebrow">Coming soon</div>
            <div class="b-primer-audio-title">"Welcome to Drunkeros" — the audio version</div>
            <div class="b-primer-audio-sub">A short primer recorded by the cast. The whole premise, the major arcs so far, and exactly where to start. We're working on it.</div>
          </div>
        </div>
      </div>
    </section>

    {/* ============== PATHS — THREE WAYS IN ============== */}
    <section class="b-paths">
      <div class="b-paths-inner">
        <div class="b-paths-header">
          <div class="sec-eyebrow">Pick a path</div>
          <h2>Three ways in.</h2>
        </div>

        <div class="b-paths-grid">

          {/* ============== PATH 1: CHARACTER SELECT ============== */}
          <article class="b-path b-path-1">
            <div class="b-path-1-flag">Most start here</div>

            {/* Character lineup — four full-body portraits */}
            <div class="b-path-1-roster">
              <div class="b-roster-character">
                <div class="b-roster-portrait">
                  <img src="/images/c2/tchuck.webp" alt="T'Chuck" loading="lazy" />
                </div>
                <div class="b-roster-name">T'Chuck</div>
              </div>
              <div class="b-roster-character">
                <div class="b-roster-portrait">
                  <img src="/images/c2/selene.webp" alt="Selene Von Esper" loading="lazy" />
                </div>
                <div class="b-roster-name">Selene</div>
              </div>
              <div class="b-roster-character">
                <div class="b-roster-portrait">
                  <img src="/images/c2/screetch.webp" alt="Screetch Echo" loading="lazy" />
                </div>
                <div class="b-roster-name">Screetch</div>
              </div>
              <div class="b-roster-character">
                <div class="b-roster-portrait">
                  <img src="/images/c2/roarc.webp" alt="R'Oarc" loading="lazy" />
                </div>
                <div class="b-roster-name">R'Oarc</div>
              </div>
            </div>

            {/* Title strip overlaid at top of roster */}
            <div class="b-path-1-strip">
              <div class="b-path-num">Path 1</div>
              <h3 class="b-path-1-title">Most start here</h3>
            </div>

            {/* Body */}
            <div class="b-path-1-body">
              <p class="b-path-body-text">
                Campaign 2 was designed as a clean entry point. A new crew on the other side of the world from Campaign 1, some time later. They start in the mountain village of Rimeford and find themselves running a resistance against a magic-banning empire.
              </p>
              <div class="b-path-meta">
                <div class="b-path-meta-item">
                  <div class="b-path-meta-num">{c2Count}</div>
                  <div class="b-path-meta-lbl">Episodes</div>
                </div>
                <div class="b-path-meta-item">
                  <div class="b-path-meta-num">2022</div>
                  <div class="b-path-meta-lbl">Started</div>
                </div>
                <div class="b-path-meta-item">
                  <div class="b-path-meta-num">Live</div>
                  <div class="b-path-meta-lbl">Status</div>
                </div>
              </div>
              <a class="b-path-cta" href={c2FirstHref}>
                <svg width="13" height="13" viewBox="0 0 12 12" aria-hidden="true"><polygon points="3,2 3,10 10,6" fill="currentColor"/></svg>
                Start C2 Episode 1
              </a>
            </div>
          </article>

          {/* ============== PATH 2: THREE POSTERS ============== */}
          <article class="b-path b-path-2">
            <div class="b-path-2-header">
              <div class="b-path-num">Path 2</div>
              <h3 class="b-path-2-title">Three samples</h3>
              <p class="b-path-2-sub">
                Three short, mostly self-contained arcs, picked to show you what kind of show this is.
              </p>
            </div>

            <div class="b-path-2-posters">
              <a class="b-poster" href={bananaFosterHref} style="--poster-bg: #f5d96f;">
                <div class="b-poster-image" style="background-image: url('/images/begin/sample-banana-foster.jpg');"></div>
                <div class="b-poster-scrim"></div>
                <div class="b-poster-content">
                  <div class="b-poster-tag">2 episodes</div>
                  <div class="b-poster-title">Bananas Foster</div>
                  <div class="b-poster-sub">The PC that was so hateful the DM killed him after two episodes.</div>
                  <div class="b-poster-credit">Art by <a href="https://bridgitconnell.com/" target="_blank" rel="noopener" onclick="event.stopPropagation()">Bridgit Connell</a></div>
                </div>
              </a>

              <a class="b-poster" href={kevimpHref} style="--poster-bg: #1a2620;">
                <div class="b-poster-image b-poster-image-light" style="background-image: url('/images/begin/sample-kevimp.webp');"></div>
                <div class="b-poster-scrim"></div>
                <div class="b-poster-content">
                  <div class="b-poster-tag">2 episodes · Holiday</div>
                  <div class="b-poster-title">Sweeties Day &amp; Volcanic Mansion Alone</div>
                  <div class="b-poster-sub">Reverse Home Alone. The party tries to break into the volcanic mansion of a fire-elemental house imp.</div>
                  <div class="b-poster-credit">Art by <a href="https://ko-fi.com/killurmonkey" target="_blank" rel="noopener" onclick="event.stopPropagation()">Killurmonkey</a></div>
                </div>
              </a>

              <a class="b-poster" href={okayByeHref} style="--poster-bg: #d4c39a;">
                <div class="b-poster-image" style="background-image: url('/images/begin/sample-okay-bye.jpg');"></div>
                <div class="b-poster-scrim"></div>
                <div class="b-poster-content">
                  <div class="b-poster-tag">1 episode</div>
                  <div class="b-poster-title">"Okay, Bye!"</div>
                  <div class="b-poster-sub">C1 Episode 122. We will not describe what happens.</div>
                  <div class="b-poster-credit">Art by <a href="https://www.dylanekren.com/" target="_blank" rel="noopener" onclick="event.stopPropagation()">Dylan Ekren</a></div>
                </div>
              </a>
            </div>
          </article>

          {/* ============== PATH 3: CINEMATIC ROSTER ============== */}
          <article class="b-path b-path-3">
            <div class="b-path-3-image">
              <img src="/images/begin/path-3-roster.jpg" alt="A vast roster of characters from twelve years of Drunkeros" loading="lazy" />
              <div class="b-path-3-image-overlay"></div>
              <div class="b-path-3-image-credit">Art by <a href="https://ko-fi.com/killurmonkey" target="_blank" rel="noopener">Killurmonkey</a></div>
            </div>
            <div class="b-path-3-content">
              <div class="b-path-3-text">
                <div class="b-path-num">Path 3</div>
                <h3 class="b-path-3-title">The full saga</h3>
                <p class="b-path-body-text">
                  For the completionists, the truck drivers, and our hyperfixation buddies. Episode one is from 2012, when we were called <em>Drunks and Dragons</em> and rolling 4th edition because 5e wasn't out yet. We switch to 5e around episode 126 but roleplay is roleplay. Some of our best stuff is in the early run.
                </p>
              </div>
              <div class="b-path-3-side">
                <div class="b-path-meta">
                  <div class="b-path-meta-item">
                    <div class="b-path-meta-num">{totalEpisodes}</div>
                    <div class="b-path-meta-lbl">Episodes</div>
                  </div>
                  <div class="b-path-meta-item">
                    <div class="b-path-meta-num">{totalHours}h</div>
                    <div class="b-path-meta-lbl">Run time</div>
                  </div>
                  <div class="b-path-meta-item">
                    <div class="b-path-meta-num">2012</div>
                    <div class="b-path-meta-lbl">Started</div>
                  </div>
                </div>
                <a class="b-path-cta b-path-cta-secondary" href={c1FirstHref}>
                  <svg width="13" height="13" viewBox="0 0 12 12" aria-hidden="true"><polygon points="3,2 3,10 10,6" fill="currentColor"/></svg>
                  Start at episode one
                </a>
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    {/* ============== WHAT YOU'RE GETTING INTO ============== */}
    <section class="b-context">
      <div class="b-context-inner">
        <div class="b-context-header">
          <div class="sec-eyebrow">A few things to know</div>
          <h2>What you're getting into.</h2>
        </div>

        <div class="b-context-grid">
          <div class="b-context-card">
            <div class="b-context-card-eyebrow">The show</div>
            <div class="b-context-card-title">It's a real campaign.</div>
            <p class="b-context-card-body">
              We took our characters from level 1 to level 20 in Campaign 1. We're doing it again in Campaign 2. Real progression, real stakes, real consequences over years. Find a starting point and stay there for a few episodes.
            </p>
          </div>
          <div class="b-context-card">
            <div class="b-context-card-eyebrow">The world</div>
            <div class="b-context-card-title">Drunkeros is dumb.</div>
            <p class="b-context-card-body">
              Not in a "we don't take it seriously" way. In a "the time the players inadvertently caused The Demon Apocalypse" way. The lore is rich and stupid. We catalog all of it on <a href="https://dndpodcast.fandom.com/" target="_blank" rel="noopener">the wiki</a>, mostly so we can remember it ourselves.
            </p>
          </div>
          <div class="b-context-card">
            <div class="b-context-card-eyebrow">The room</div>
            <div class="b-context-card-title">A seat at the table.</div>
            <p class="b-context-card-body">
              The thing that sets the show apart is what it actually feels like to listen. You have a seat at the table with five of your funniest friends. It's a real game, so you hear table talk and tangents alongside the epic fantasy adventure.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ============== CLOSING CTA ============== */}
    <section class="b-final">
      <div class="b-final-inner">
        <h2 class="b-final-title">Just listen to one.</h2>
        <p class="b-final-body">
          Unless you are a coward.
        </p>
        <div class="b-final-actions">
          <a class="btn-p" href={c2FirstHref}>
            <svg width="13" height="13" viewBox="0 0 12 12" aria-hidden="true"><polygon points="3,2 3,10 10,6" fill="currentColor"/></svg>
            Start with C2 Episode 1
          </a>
          <a class="btn-s" href="/episodes">Browse all episodes</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .begin { background: var(--bg); }

  /* ============== HERO ============== */
  .b-hero {
    position: relative;
    overflow: hidden;
    padding: 100px 40px 80px;
    background-color: #0a1410;
  }
  .b-hero-bg {
    position: absolute; inset: 0;
    background-image: url('/images/drunkeros-map.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.5;
  }
  .b-hero-overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(10,15,12,0.5) 0%, rgba(10,15,12,0.85) 70%, rgba(10,15,12,1) 100%),
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);
  }
  .b-hero-inner {
    position: relative; z-index: 2;
    max-width: 900px; margin: 0 auto;
    text-align: center;
  }
  .b-hero-eyebrow {
    font-size: var(--t-small); letter-spacing: var(--ls-eyebrow);
    color: var(--gold); font-weight: var(--fw-semibold);
    text-transform: uppercase; margin-bottom: 22px;
  }
  .b-hero-title {
    font-family: var(--font-display);
    font-size: var(--t-display-1);
    line-height: var(--lh-tight); font-weight: var(--fw-bold);
    color: #f5f0e0; letter-spacing: var(--ls-display);
    margin-bottom: 22px;
    text-shadow: 0 2px 24px rgba(0,0,0,0.6);
  }
  .b-hero-tag {
    font-family: var(--font-editorial);
    font-style: italic;
    font-size: var(--t-body-lg);
    color: #d8d4c5; line-height: var(--lh-normal);
    max-width: 600px; margin: 0 auto;
    text-shadow: 0 1px 8px rgba(0,0,0,0.6);
  }

  /* ============== PRIMER ============== */
  .b-primer { padding: 70px 40px; background: var(--bg); }
  .b-primer-inner { max-width: 900px; margin: 0 auto; }
  .b-primer-eyebrow {
    font-size: var(--t-small); letter-spacing: var(--ls-eyebrow);
    color: var(--green); font-weight: var(--fw-semibold);
    text-transform: uppercase; margin-bottom: 14px;
  }
  .b-primer-title {
    font-family: var(--font-display);
    font-size: var(--t-h2);
    font-weight: var(--fw-bold); color: #f5f0e0;
    letter-spacing: var(--ls-display); line-height: var(--lh-tight);
    margin-bottom: 28px;
  }
  .b-primer-body {
    font-size: var(--t-body); color: var(--text-2);
    line-height: var(--lh-relaxed); margin-bottom: 18px;
  }
  .b-primer-body em {
    color: var(--gold); font-style: italic; font-weight: var(--fw-medium);
  }
  .b-primer-audio {
    margin-top: 36px; padding: 22px 26px;
    background: var(--surface);
    border: 0.5px dashed rgba(212,175,55,0.4);
    border-radius: 12px;
    display: flex; gap: 20px; align-items: center;
  }
  .b-primer-audio-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(212,175,55,0.1);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: var(--gold);
  }
  .b-primer-audio-body { flex: 1; }
  .b-primer-audio-eyebrow {
    font-size: var(--t-small); letter-spacing: var(--ls-eyebrow); color: var(--gold);
    font-weight: var(--fw-semibold); text-transform: uppercase; margin-bottom: 4px;
  }
  .b-primer-audio-title {
    font-family: var(--font-editorial);
    font-size: var(--t-h4); font-weight: var(--fw-semibold);
    color: var(--text); margin-bottom: 4px; letter-spacing: var(--ls-tight);
  }
  .b-primer-audio-sub {
    font-size: var(--t-body-sm); color: var(--text-3); line-height: var(--lh-normal);
  }

  /* ============== PATHS ============== */
  .b-paths {
    padding: 80px 40px;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
  }
  .b-paths-inner { max-width: 1280px; margin: 0 auto; }
  .b-paths-header { text-align: center; margin-bottom: 50px; }
  .b-paths-header .sec-eyebrow {
    display: inline-block;
    font-size: var(--t-small); letter-spacing: var(--ls-eyebrow);
    color: var(--green); font-weight: var(--fw-semibold);
    text-transform: uppercase; margin-bottom: 14px;
  }
  .b-paths-header h2 {
    font-family: var(--font-display);
    font-size: var(--t-h2);
    font-weight: var(--fw-bold); color: #f5f0e0;
    letter-spacing: var(--ls-display); line-height: var(--lh-tight);
  }

  /* Asymmetric grid: top row 50/50, bottom row full width */
  .b-paths-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "p1 p2"
      "p3 p3";
    gap: 18px;
  }
  .b-path-1 { grid-area: p1; }
  .b-path-2 { grid-area: p2; }
  .b-path-3 { grid-area: p3; }

  .b-path {
    background: var(--surface);
    border-radius: 14px;
    border: 0.5px solid var(--border);
    position: relative;
    transition: transform 0.2s, border-color 0.2s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .b-path:hover {
    transform: translateY(-3px);
    border-color: rgba(151,196,89,0.3);
  }

  /* Shared elements */
  .b-path-num {
    font-family: var(--font-display);
    font-size: var(--t-small); letter-spacing: var(--ls-eyebrow);
    color: var(--gold); font-weight: var(--fw-semibold);
    text-transform: uppercase;
  }
  .b-path-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    padding: 18px 0;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 22px;
  }
  .b-path-meta-item { text-align: center; }
  /* Stat number — bespoke 18px, leaving as-is per stat-block guidance */
  .b-path-meta-num {
    font-family: var(--font-display);
    font-size: 18px; font-weight: var(--fw-bold);
    color: var(--gold); line-height: 1; letter-spacing: var(--ls-display);
  }
  .b-path-meta-lbl {
    font-size: var(--t-tiny); letter-spacing: var(--ls-eyebrow); color: var(--text-3);
    margin-top: 6px; font-weight: var(--fw-medium); text-transform: uppercase;
  }
  .b-path-cta {
    background: var(--green); color: #0a0f0c;
    padding: 13px 18px; border-radius: 8px;
    font-size: var(--t-small); font-weight: var(--fw-semibold);
    display: inline-flex; align-items: center; justify-content: center;
    gap: 9px; text-decoration: none;
    transition: transform 0.15s;
  }
  .b-path-cta:hover { transform: translateY(-2px); }
  .b-path-cta-secondary {
    background: rgba(212,175,55,0.12); color: var(--gold);
    border: 0.5px solid rgba(212,175,55,0.4);
  }
  .b-path-cta-secondary:hover { background: rgba(212,175,55,0.2); }
  .b-path-body-text {
    font-size: var(--t-body-sm); color: var(--text-2);
    line-height: var(--lh-relaxed); margin-bottom: 22px;
  }
  .b-path-body-text em {
    color: var(--gold); font-style: italic;
  }

  /* ============== PATH 1: CHARACTER ROSTER ============== */
  .b-path-1 {
    border-color: rgba(151,196,89,0.4);
  }
  .b-path-1-flag {
    position: absolute;
    top: 16px; left: 16px;
    background: var(--green); color: #0a0f0c;
    padding: 5px 14px; border-radius: 999px;
    font-size: var(--t-tiny); letter-spacing: var(--ls-eyebrow);
    font-weight: var(--fw-bold); text-transform: uppercase;
    z-index: 5;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  /* The four-up character roster
     Pure black background, no internal dividers — characters merge into shared space */
  .b-path-1-roster {
    position: relative;
