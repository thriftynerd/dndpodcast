---
// src/pages/episodes/[slug].astro
import Layout from '../../layouts/Layout.astro';
import EpisodeBreadcrumb from '../../components/EpisodeBreadcrumb.astro';
import EpisodeHero from '../../components/EpisodeHero.astro';
import PlayerBand from '../../components/PlayerBand.astro';
import EpisodeCast from '../../components/EpisodeCast.astro';
import ShowNotes from '../../components/ShowNotes.astro';
import Transcript from '../../components/Transcript.astro';
import EpisodeSidebar from '../../components/EpisodeSidebar.astro';
import EpisodeNav from '../../components/EpisodeNav.astro';

import { loadEpisodes, getNeighbors, type Episode } from '../../lib/rss';
import type { LineupEntry } from '../../data/lineups';

import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';

export async function getStaticPaths() {
  const episodes = await loadEpisodes();
  return episodes.map((ep) => ({
    params: { slug: ep.slug },
    props: { episode: ep },
  }));
}

interface Props {
  episode: Episode;
}

const { episode: ep } = Astro.props;
const { prev, next } = await getNeighbors(ep.slug);

// ============== TRANSCRIPT ==============
let transcript: any[] = [];
let transcriptStatus = '';
const transcriptPath = resolve(process.cwd(), `src/data/transcripts/${ep.slug}.json`);
if (existsSync(transcriptPath)) {
  try {
    const raw = readFileSync(transcriptPath, 'utf-8');
    const parsed = JSON.parse(raw);
    if (Array.isArray(parsed)) {
      transcript = parsed;
      transcriptStatus = 'Auto-generated · AssemblyAI';
    } else if (parsed.segments) {
      transcript = parsed.segments;
      transcriptStatus = parsed.status || 'Auto-generated · AssemblyAI';
    }
  } catch (e) {
    console.warn(`[transcript] failed to parse ${transcriptPath}`, e);
  }
}

// ============== EPISODE NOTES (editorial show notes + mentions) ==============
// Optional per-episode JSON at src/data/episode-notes/[slug].json
let episodeNotes: any = null;
const notesPath = resolve(process.cwd(), `src/data/episode-notes/${ep.slug}.json`);
if (existsSync(notesPath)) {
  try {
    episodeNotes = JSON.parse(readFileSync(notesPath, 'utf-8'));
  } catch (e) {
    console.warn(`[episode-notes] failed to parse ${notesPath}`, e);
  }
}

// ============== NPC REGISTRY (recurring characters with thumbnails) ==============
// Optional shared registry at src/data/npcs.json. Episode notes can either
// reference an NPC by `id` (which pulls in the canonical name + thumbnail)
// or just inline a `name` for one-off characters.
type NpcEntry = { name: string; thumbnail?: string; tagline?: string };
let npcRegistry: Record<string, NpcEntry> = {};
const npcsPath = resolve(process.cwd(), 'src/data/npcs.json');
if (existsSync(npcsPath)) {
  try {
    npcRegistry = JSON.parse(readFileSync(npcsPath, 'utf-8'));
  } catch (e) {
    console.warn('[npcs] failed to parse npc registry', e);
  }
}

// ============== LINEUP → CAST CONVERSION ==============
const AVATAR_CLASSES: Record<string, string> = {
  'Mike Bachmann': 'avatar-bach',
  'Michael Bachmann': 'avatar-bach',
  'Bachmann': 'avatar-bach',
  'Jennifer Cheek': 'avatar-jen',
  'Nika Howard': 'avatar-nika',
  'Tim Lanning': 'avatar-tim',
  'Michael DiMauro': 'avatar-michael',
  'Steven Strom': 'avatar-strom',
  'Vince Kenny': 'avatar-vince',
};

function initialsFor(player: string): string {
  return player
    .split(/\s+/)
    .map((part) => part.charAt(0))
    .filter(Boolean)
    .slice(0, 2)
    .join('')
    .toUpperCase();
}

function buildRole(entry: LineupEntry): string {
  if (entry.role === 'dm') return 'Dungeon Master';
  const base = entry.character ? `as ${entry.character}` : '';
  const flags: string[] = [];
  if (entry.firstAppearance) flags.push('first appearance');
  if (entry.finalAppearance) flags.push('final appearance');
  if (entry.absent) flags.push('absent');
  if (entry.guest) flags.push('guest');
  if (flags.length > 0) {
    return `${base}${base ? ' · ' : ''}${flags.join(' · ')}`;
  }
  return base;
}

const castFromLineup = (ep.lineup ?? [])
  .filter((entry) => !entry.absent)
  .map((entry) => ({
    player: entry.player,
    initials: initialsFor(entry.player),
    role: buildRole(entry),
    avatarClass: AVATAR_CLASSES[entry.player] ?? 'avatar-default',
    portrait: entry.portrait,
  }));

const hasLineup = castFromLineup.length > 0;

// ============== METADATA ==============
const showNotes: string[] = episodeNotes?.show_notes
  ? String(episodeNotes.show_notes)
      .split(/\n\s*\n/)
      .map((p: string) => p.trim())
      .filter(Boolean)
  : (ep.description ? [ep.description] : []);

const campaignLabel =
  ep.kind === 'c1' ? 'Campaign One' :
  ep.kind === 'c2' ? 'Campaign Two' :
  'Bonus';
const campaignHref = ep.kind === 'c1' ? '/campaign-1' : ep.kind === 'c2' ? '/campaign-2' : '/episodes';
const breadcrumbCurrent = ep.episodeNumber ? `Episode ${ep.episodeNumber}` : 'Bonus';

const dmEntry = (ep.lineup ?? []).find((e) => e.role === 'dm');
const dmName = dmEntry?.player ?? 'Michael DiMauro';

const prevLink = prev ? {
  href: `/episodes/${prev.slug}`,
  label: prev.episodeNumber ? `Episode ${prev.episodeNumber}` : 'Bonus',
  title: prev.title,
} : undefined;
const nextLink = next ? {
  href: `/episodes/${next.slug}`,
  label: next.episodeNumber ? `Episode ${next.episodeNumber}` : 'Bonus',
  title: next.title,
} : undefined;

// ============== MENTIONS ==============
// Build sidebar mention items. Characters can be either:
//   { id: "ratma", note: "..." }  → pulls name + thumbnail from npcs.json
//   { name: "Meat Chunk", note: "..." }  → inline, one-off, no thumbnail
function resolveCharacterMention(c: { id?: string; name?: string; note?: string }) {
  if (c.id && npcRegistry[c.id]) {
    const reg = npcRegistry[c.id];
    return {
      type: 'character',
      name: reg.name,
      note: c.note,
      thumbnail: reg.thumbnail,
    };
  }
  return {
    type: 'character',
    name: c.name ?? '(unknown)',
    note: c.note,
  };
}

const ite = episodeNotes?.in_this_episode;
const mentions: any[] = [
  ...((ite?.characters ?? []).map(resolveCharacterMention)),
  ...((ite?.locations  ?? []).map((l: any) => ({ type: 'location',  name: l.name, note: l.note }))),
  ...((ite?.callbacks  ?? []).map((c: any) => ({ type: 'callback',  name: c.name, note: c.note }))),
];
---

<Layout title={`${ep.title} · ${campaignLabel}, Episode ${ep.episodeNumber ?? 'Bonus'}`}>
  <EpisodeBreadcrumb
    campaignHref={campaignHref}
    campaignLabel={campaignLabel}
    current={breadcrumbCurrent}
  />

  <EpisodeHero
    campaign={campaignLabel}
    episodeNumber={String(ep.episodeNumber ?? 'Bonus')}
    title={ep.title}
    description={ep.description}
    artUrl={ep.artUrl}
    releaseDate={ep.releaseDate}
    duration={ep.duration}
    season={`Season ${ep.season}`}
    dm={dmName}
  />

  <PlayerBand showId={ep.acastShowId} episodeId={ep.acastEpisodeId} />

  <section class="ep-body">
    <div class="ep-content">
      {hasLineup && <EpisodeCast cast={castFromLineup} />}
      <ShowNotes paragraphs={showNotes} />
      {transcript.length > 0 && (
        <Transcript segments={transcript} status={transcriptStatus} />
      )}
    </div>
    <EpisodeSidebar mentions={mentions} />
  </section>

  <EpisodeNav prev={prevLink} next={nextLink} />
</Layout>

<style>
  .ep-body { max-width: 1280px; margin: 0 auto; padding: 60px 40px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 320px); gap: 60px; align-items: start; }
  .ep-content { min-width: 0; }

  @media (max-width: 1024px) {
    .ep-body { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 900px) {
    .ep-body { padding: 40px 24px; }
  }
</style>