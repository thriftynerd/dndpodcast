---
import type { ArchiveEpisode } from '../data/episodes-archive';
import { fmtDate, groupByYear } from '../data/episodes-archive';

interface Props {
  episodes: ArchiveEpisode[];
  initialPageSize?: number;
}

const { episodes, initialPageSize = 25 } = Astro.props;

// Group all episodes by year, newest year first; episodes within each year newest-first.
const sorted = [...episodes].sort((a, b) => b.date.localeCompare(a.date));
const grouped = groupByYear(sorted);
---

<section class="all-section">
  <div class="all-header">
    <div>
      <div class="all-eyebrow">The complete catalog</div>
      <h2 class="all-title">Every episode</h2>
    </div>
    <div class="all-controls">
      <span>Sort:</span>
      <select id="sort-select">
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
      </select>
    </div>
  </div>

  <div id="episode-list" data-page-size={initialPageSize}>
    {grouped.map((group) => (
      <div class="year-group" data-year={group.year}>
        <div class="year-label">
          {group.year}
          <span class="year-label-count">{group.episodes.length} episode{group.episodes.length === 1 ? '' : 's'}</span>
        </div>
        {group.episodes.map((ep) => {
          const numDisplay = ep.episodeNumber ? `#${ep.episodeNumber}` : 'Bonus';
          const kindLabel = ep.kind === 'c1' ? 'C1' : ep.kind === 'c2' ? 'C2' : 'Bonus';
          return (
            
              <a href={`/episodes/${ep.slug}`}
              class={`list-row kind-${ep.kind}`}
              data-kind={ep.kind}
              data-title={ep.title.toLowerCase()}
              data-description={ep.description.toLowerCase()}
              data-date={ep.date}
            >
              <div class="lr-num">{numDisplay}</div>
              <div class="lr-art">
                {ep.artUrl ? <img src={ep.artUrl} alt="" /> : <div class="lr-art-placeholder">{ep.kind.toUpperCase()}</div>}
              </div>
              <div class="lr-info">
                <div class="lr-title"><span class={`lr-kind-pill ${ep.kind}`}>{kindLabel}</span>{ep.title}</div>
                <div class="lr-meta">{fmtDate(ep.date)}</div>
              </div>
              <div class="lr-duration">{ep.duration}</div>
              <div class="lr-play">
                <svg width="11" height="11" viewBox="0 0 12 12"><polygon points="3,2 3,10 10,6" fill="currentColor"/></svg>
              </div>
            </a>
          );
        })}
      </div>
    ))}
  </div>

  <div class="empty-state" id="empty-state" style="display:none;">
    <div class="empty-state-title">No episodes found.</div>
    <div class="empty-state-sub">Try a different search or clear the filter.</div>
  </div>

  <div class="load-more" id="load-more">
    <button class="load-more-btn" id="load-more-btn" type="button">Load more episodes</button>
  </div>
</section>

<style>
  .all-section { max-width: 1280px; margin: 0 auto; padding: 30px 40px 60px; }
  .all-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; gap: 20px; flex-wrap: wrap; }
  .all-eyebrow { font-size: 12px; letter-spacing: 0.28em; color: var(--green); font-weight: 600; margin-bottom: 10px; }
  .all-title { font-family: "Cinzel", Georgia, serif; font-size: clamp(1.75rem, 2.8vw, 2.4rem); font-weight: 700; line-height: 1.1; color: #f5f0e0; letter-spacing: 0.005em; }
  .all-controls { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-3); }
  .all-controls select { background: var(--surface); color: var(--text); border: 0.5px solid var(--border-2); border-radius: 6px; padding: 6px 10px; font-size: 13px; font-family: inherit; cursor: pointer; }

  .year-group { margin-bottom: 30px; }
  .year-label { font-family: "Cinzel", Georgia, serif; font-size: 13px; letter-spacing: 0.2em; color: var(--gold); font-weight: 700; padding: 14px 0; border-bottom: 0.5px solid var(--border-2); margin-bottom: 4px; display: flex; align-items: center; gap: 14px; }
  .year-label-count { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 11px; letter-spacing: 0.18em; color: var(--text-3); font-weight: 500; text-transform: uppercase; }

  .list-row { display: grid; grid-template-columns: 60px 80px minmax(0, 1fr) auto 32px; gap: 16px; align-items: center; padding: 12px 14px; border-radius: 8px; text-decoration: none; transition: background 0.15s; }
  .list-row:hover { background: var(--surface); }
  .lr-num { font-family: "Cinzel", Georgia, serif; font-size: 12px; color: var(--text-4); font-weight: 600; letter-spacing: 0.05em; }
  .lr-art { width: 80px; aspect-ratio: 16/9; border-radius: 5px; overflow: hidden; background: var(--bg-2); flex-shrink: 0; }
  .lr-art img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lr-art-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: "Cinzel", Georgia, serif; color: var(--text-4); font-size: 13px; font-weight: 700; letter-spacing: 0.08em; }
  .lr-info { min-width: 0; }
  .lr-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: 16px; font-weight: 600; color: var(--text); line-height: 1.3; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .lr-kind-pill { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 9px; letter-spacing: 0.18em; font-weight: 700; padding: 2px 6px; border-radius: 3px; text-transform: uppercase; }
  .lr-kind-pill.c1 { background: rgba(212,175,55,0.14); color: var(--gold); }
  .lr-kind-pill.c2 { background: rgba(151,196,89,0.14); color: var(--green); }
  .lr-kind-pill.bonus { background: rgba(168,127,199,0.14); color: #c5a5d6; }
  .lr-meta { font-size: 12px; color: var(--text-3); margin-top: 2px; }
  .lr-duration { font-size: 12px; color: var(--text-3); white-space: nowrap; }
  .lr-play { color: var(--text-4); transition: color 0.2s; }
  .list-row:hover .lr-play { color: var(--green); }

  .empty-state { padding: 80px 24px; text-align: center; }
  .empty-state-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
  .empty-state-sub { font-size: 14px; color: var(--text-3); }

  .load-more { padding: 30px 0; text-align: center; }
  .load-more-btn { background: var(--surface); color: var(--text); border: 0.5px solid var(--border-2); border-radius: 8px; padding: 12px 28px; font-size: 14px; font-weight: 500; cursor: pointer; font-family: inherit; transition: background 0.2s; }
  .load-more-btn:hover { background: var(--surface-2); }

  @media (max-width: 900px) {
    .all-section { padding: 20px 24px 40px; }
    .list-row { grid-template-columns: 60px minmax(0, 1fr) auto; gap: 12px; }
    .lr-art { display: none; }
  }
</style>

<script is:inline>
  (function() {
    var listEl = document.getElementById('episode-list');
    var emptyState = document.getElementById('empty-state');
    var loadMore = document.getElementById('load-more');
    var loadMoreBtn = document.getElementById('load-more-btn');
    var sortSelect = document.getElementById('sort-select');
    if (!listEl) return;

    var pageSize = parseInt(listEl.getAttribute('data-page-size'), 10) || 25;
    var visibleCount = pageSize;
    var currentKind = 'all';
    var currentQuery = '';
    var currentSort = 'newest';

    var rows = Array.prototype.slice.call(listEl.querySelectorAll('.list-row'));
    var yearGroups = Array.prototype.slice.call(listEl.querySelectorAll('.year-group'));

    function rowMatches(row) {
      var kind = row.getAttribute('data-kind');
      if (currentKind !== 'all' && kind !== currentKind) return false;
      if (!currentQuery) return true;
      var hay = row.getAttribute('data-title') + ' ' + row.getAttribute('data-description');
      return hay.indexOf(currentQuery) >= 0;
    }

    function applySort() {
      // Sort year groups
      yearGroups.sort(function(a, b) {
        var ya = a.getAttribute('data-year');
        var yb = b.getAttribute('data-year');
        return currentSort === 'newest' ? yb.localeCompare(ya) : ya.localeCompare(yb);
      });
      yearGroups.forEach(function(g) { listEl.appendChild(g); });

      // Sort rows within each year group
      yearGroups.forEach(function(g) {
        var groupRows = Array.prototype.slice.call(g.querySelectorAll('.list-row'));
        groupRows.sort(function(a, b) {
          var da = a.getAttribute('data-date');
          var db = b.getAttribute('data-date');
          return currentSort === 'newest' ? db.localeCompare(da) : da.localeCompare(db);
        });
        groupRows.forEach(function(r) { g.appendChild(r); });
      });
    }

    function render() {
      var matching = rows.filter(rowMatches);
      var total = matching.length;
      var showing = Math.min(visibleCount, total);

      // Hide all rows first
      rows.forEach(function(r) { r.style.display = 'none'; });

      // Show first N matching rows
      var shown = 0;
      // We need to walk in DOM order, so iterate rows (already in document order)
      // and pick the first `showing` matches
      for (var i = 0; i < rows.length && shown < showing; i++) {
        if (rowMatches(rows[i])) {
          rows[i].style.display = '';
          shown++;
        }
      }

      // Hide year-group headers that have no visible rows
      yearGroups.forEach(function(g) {
        var visibleRows = Array.prototype.slice.call(g.querySelectorAll('.list-row')).filter(function(r) { return r.style.display !== 'none'; });
        var label = g.querySelector('.year-label');
        if (visibleRows.length === 0) {
          g.style.display = 'none';
        } else {
          g.style.display = '';
          // Update count to show only visible
          var countEl = label.querySelector('.year-label-count');
          if (countEl) {
            countEl.textContent = visibleRows.length + ' episode' + (visibleRows.length === 1 ? '' : 's');
          }
        }
      });

      // Empty state
      if (total === 0) {
        listEl.style.display = 'none';
        emptyState.style.display = '';
        loadMore.style.display = 'none';
      } else {
        listEl.style.display = '';
        emptyState.style.display = 'none';
        if (showing < total) {
          loadMore.style.display = '';
          loadMoreBtn.textContent = 'Load more (' + (total - showing) + ' remaining)';
        } else {
          loadMore.style.display = 'none';
        }
      }

      // Tell the search band how many we're showing
      var hasFilter = currentKind !== 'all' || currentQuery !== '';
      document.dispatchEvent(new CustomEvent('archive:results-count', {
        detail: { showing: hasFilter, total: total }
      }));
    }

    // Listen for filter changes from EpisodeSearchBand
    document.addEventListener('archive:filter-changed', function(e) {
      var detail = e.detail || {};
      currentKind = detail.kind || 'all';
      currentQuery = detail.query || '';
      visibleCount = pageSize;

      // Hide curated rails when filter is active (let the parent page handle this via CSS)
      var hasFilter = currentKind !== 'all' || currentQuery !== '';
      var rails = document.getElementById('curated-rails-wrapper');
      if (rails) rails.style.display = hasFilter ? 'none' : '';

      render();
    });

    if (sortSelect) {
      sortSelect.addEventListener('change', function(e) {
        currentSort = e.target.value;
        visibleCount = pageSize;
        applySort();
        render();
      });
    }

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', function() {
        visibleCount += pageSize;
        render();
      });
    }

    // Initial render
    render();
  })();
</script>