---
// Subscribe dropdown — a primary nav CTA that opens to a list of platform
// links so visitors can subscribe in their podcast app of choice.
//
// Featured platforms ordered roughly by your audience distribution:
// Spotify (40%) → Apple (18%) → Overcast (5%) → YouTube → catchall.
// The Acast public page acts as the catchall ("More podcast apps") — it
// auto-detects the visitor's platform and forwards them to it.

const PLATFORMS = [
  {
    name: 'Spotify',
    url: 'https://open.spotify.com/show/06gMyMkL1VbXNykzfqZU7S',
    color: '#1DB954',
    icon: 'spotify',
  },
  {
    name: 'Apple Podcasts',
    url: 'https://podcasts.apple.com/us/podcast/greetings-adventurers-dungeons-and-dragons-5e-actual-play/id581324591',
    color: '#a259e5',
    icon: 'apple',
  },
  {
    name: 'Overcast',
    url: 'https://overcast.fm/itunes581324591',
    color: '#fc7e0f',
    icon: 'overcast',
  },
  {
    name: 'YouTube',
    url: 'https://youtube.com/geeklyinc',
    color: '#FF0000',
    icon: 'youtube',
  },
];

const CATCHALL_URL = 'https://shows.acast.com/greetings-adventurers';
---

<div class="subscribe">
  <button class="subscribe-trigger" type="button" aria-haspopup="true" aria-expanded="false">
    <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
      <polygon points="3,2 3,10 10,6" fill="currentColor"/>
    </svg>
    Subscribe
    <svg class="subscribe-chevron" width="10" height="10" viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2,4 L6,8 L10,4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="subscribe-menu" role="menu" hidden>
    <div class="subscribe-eyebrow">Listen in your favorite app</div>
    {PLATFORMS.map((p) => (
      <a class="subscribe-item" href={p.url} target="_blank" rel="noopener" role="menuitem" style={`--platform-color: ${p.color}`}>
        <span class="subscribe-icon" data-icon={p.icon}>
          {p.icon === 'spotify' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.59 14.42c-.18.3-.57.4-.87.21-2.39-1.46-5.4-1.79-8.94-.98-.34.08-.68-.13-.76-.47-.08-.34.13-.68.47-.76 3.88-.89 7.21-.51 9.89 1.13.3.18.4.57.21.87zm1.22-2.72c-.23.37-.71.49-1.09.26-2.74-1.68-6.91-2.17-10.14-1.19-.42.13-.86-.11-.99-.53-.13-.42.11-.86.53-.99 3.69-1.12 8.29-.57 11.43 1.36.38.23.49.71.26 1.09zm.11-2.83C14.66 8.87 9.36 8.7 6.31 9.63c-.5.15-1.03-.13-1.18-.63s.13-1.03.63-1.18c3.5-1.06 9.36-.86 13.04 1.32.45.27.6.85.33 1.3-.27.45-.85.6-1.3.33z"/></svg>
          )}
          {p.icon === 'apple' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 1.5c5.79 0 10.5 4.71 10.5 10.5S17.79 22.5 12 22.5 1.5 17.79 1.5 12 6.21 1.5 12 1.5zm0 13.04c-1.46 0-2.65 1.19-2.65 2.65 0 1.13.71 2.1 1.71 2.48-.04-.53-.07-1.36 0-1.94.07-.52.46-3.31.46-3.31s-.12-.24-.12-.59c0-.55.32-.96.72-.96.34 0 .5.25.5.55 0 .34-.22.84-.33 1.31-.09.39.2.71.58.71.7 0 1.24-.74 1.24-1.81 0-.94-.68-1.61-1.65-1.61-1.13 0-1.79.85-1.79 1.72 0 .34.13.71.29.91.03.04.04.07.03.11l-.11.45c-.02.07-.06.09-.13.05-.5-.23-.81-.95-.81-1.53 0-1.24.9-2.39 2.6-2.39 1.36 0 2.42.97 2.42 2.27 0 1.36-.85 2.45-2.04 2.45-.4 0-.78-.21-.91-.45 0 0-.2.76-.25.95-.09.34-.32.77-.48 1.03.36.11.74.17 1.14.17 2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4c0 1.46.79 2.74 1.96 3.43-.16-.55-.31-1.39-.06-1.99.22-.54 1.46-6.16 1.46-6.16s-.37-.74-.37-1.83c0-1.71 1-2.99 2.24-2.99 1.06 0 1.57.79 1.57 1.74 0 1.06-.67 2.65-1.02 4.13-.29 1.23.62 2.24 1.84 2.24 2.21 0 3.91-2.33 3.91-5.69 0-2.98-2.14-5.06-5.19-5.06-3.54 0-5.62 2.65-5.62 5.39 0 1.07.41 2.21.92 2.84a.37.37 0 01.09.36c-.09.39-.31 1.27-.35 1.45-.05.23-.18.28-.42.17-1.55-.72-2.52-2.99-2.52-4.81 0-3.92 2.85-7.51 8.21-7.51 4.31 0 7.66 3.07 7.66 7.18 0 4.28-2.7 7.73-6.45 7.73-1.26 0-2.45-.65-2.85-1.43 0 0-.61 2.32-.76 2.89-.27 1.05-1.01 2.36-1.5 3.16C9.47 19.39 11.69 19.5 12 19.5c4.14 0 7.5-3.36 7.5-7.5S16.14 4.5 12 4.5 4.5 7.86 4.5 12c0 2.45 1.18 4.62 3 5.99-.59-.42-1-.99-1-1.74 0-.81.46-1.49 1.06-1.49.5 0 .74.37.74.82 0 .5-.32 1.25-.48 1.94-.13.58.29 1.05.86 1.05 1.04 0 1.83-1.09 1.83-2.66 0-1.39-1-2.36-2.43-2.36-1.66 0-2.63 1.24-2.63 2.53 0 .5.19 1.04.43 1.34.05.06.05.11.04.17l-.16.65c-.03.11-.08.13-.19.08-.74-.34-1.2-1.41-1.2-2.27 0-1.83 1.33-3.51 3.83-3.51 2.01 0 3.57 1.43 3.57 3.34 0 2-1.26 3.61-3.01 3.61-.59 0-1.14-.31-1.33-.67 0 0-.29 1.12-.36 1.4-.13.5-.48 1.13-.71 1.51z"/></svg>
          )}
          {p.icon === 'overcast' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 17l-3-7 3 1 3-1-3 7zm0-9.5c-1.93 0-3.5-1.57-3.5-3.5S10.07 5.5 12 5.5s3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z"/></svg>
          )}
          {p.icon === 'youtube' && (
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23 7.3a2.7 2.7 0 00-1.9-1.9C19.5 5 12 5 12 5s-7.5 0-9.1.4A2.7 2.7 0 001 7.3 28 28 0 00.6 12 28 28 0 001 16.7a2.7 2.7 0 001.9 1.9C4.5 19 12 19 12 19s7.5 0 9.1-.4a2.7 2.7 0 001.9-1.9 28 28 0 00.4-4.7 28 28 0 00-.4-4.7zM9.8 15V9l5.3 3z"/></svg>
          )}
        </span>
        <span class="subscribe-name">{p.name}</span>
        <svg class="subscribe-arrow" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true">
          <path d="M3 3h6v6M3 9l6-6" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </a>
    ))}

    <a class="subscribe-more" href={CATCHALL_URL} target="_blank" rel="noopener" role="menuitem">
      More podcast apps
      <svg viewBox="0 0 12 12" width="11" height="11" aria-hidden="true">
        <path d="M3 6h6M6 3l3 3-3 3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .subscribe { position: relative; display: inline-flex; }

  .subscribe-trigger {
    background: var(--green);
    color: #0a0f0c;
    padding: 9px 16px;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s;
  }
  .subscribe-trigger:hover {
    background: #a8d166;
  }
  .subscribe-trigger[aria-expanded="true"] {
    background: #a8d166;
  }
  .subscribe-chevron {
    transition: transform 0.15s;
    margin-left: 2px;
  }
  .subscribe-trigger[aria-expanded="true"] .subscribe-chevron {
    transform: rotate(180deg);
  }

  .subscribe-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 280px;
    background: var(--surface);
    border: 0.5px solid var(--border-2);
    border-radius: 10px;
    padding: 8px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
    z-index: 200;
    animation: subscribe-fade-in 0.15s ease-out;
  }
  .subscribe-menu[hidden] { display: none; }

  @keyframes subscribe-fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .subscribe-eyebrow {
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--text-4);
    font-weight: 600;
    text-transform: uppercase;
    padding: 6px 12px 8px;
  }

  .subscribe-item {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 9px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.12s;
  }
  .subscribe-item:hover {
    background: var(--surface-2);
  }
  .subscribe-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--platform-color, var(--text-2));
  }
  .subscribe-name {
    font-size: 14px;
    font-weight: 500;
  }
  .subscribe-arrow {
    color: var(--text-4);
    transition: color 0.12s, transform 0.12s;
  }
  .subscribe-item:hover .subscribe-arrow {
    color: var(--text-2);
    transform: translate(1px, -1px);
  }

  .subscribe-more {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 12px;
    margin-top: 4px;
    border-top: 0.5px solid var(--border);
    border-radius: 0 0 6px 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--green);
    text-decoration: none;
    transition: color 0.12s;
  }
  .subscribe-more:hover {
    color: #b8db82;
  }
  .subscribe-more svg {
    color: currentColor;
  }

  @media (max-width: 720px) {
    .subscribe-menu {
      right: auto;
      left: 0;
      min-width: 260px;
    }
  }
</style>

<script>
  // Open/close the subscribe dropdown. Closes on outside click and Escape.
  document.querySelectorAll('.subscribe').forEach((wrap) => {
    const trigger = wrap.querySelector('.subscribe-trigger');
    const menu = wrap.querySelector('.subscribe-menu');
    if (!trigger || !menu) return;

    const close = () => {
      menu.setAttribute('hidden', '');
      trigger.setAttribute('aria-expanded', 'false');
    };
    const open = () => {
      menu.removeAttribute('hidden');
      trigger.setAttribute('aria-expanded', 'true');
    };

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    });

    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  });
</script>