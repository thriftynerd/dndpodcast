---
import Subscribe from './Subscribe.astro';

const path = Astro.url.pathname;

const isActive = (matchers: string[]) =>
  matchers.some((m) => path === m || path.startsWith(m + '/'));

const PATREON_URL = 'https://patreon.com/dndpodcast';
---

<nav class="nav">
  <a class="brand-mark" href="/">
    <img class="brand-mark-img" src="/images/logo-white.png" alt="Greetings, Adventurers!" />
  </a>
  <div class="nav-items">
    {isActive(['/episodes'])
      ? <span class="active">Episodes</span>
      : <a href="/episodes" class="nav-link">Episodes</a>}

    {isActive(['/cast'])
      ? <span class="active">Cast</span>
      : <a href="/cast" class="nav-link">Cast</a>}

    {isActive(['/campaign-2', '/campaign-1'])
      ? <span class="active">The world</span>
      : <a href="/campaign-2" class="nav-link">The world</a>}

    <a href="https://dndpodcast.fandom.com/" target="_blank" rel="noopener" class="nav-link">Wiki</a>

    <div class="nav-ctas">
      <a href={PATREON_URL} target="_blank" rel="noopener" class="nav-support">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        Support us
      </a>
      <Subscribe />
    </div>
  </div>
</nav>

<style>
  .nav {
    padding: 18px 40px;
    display: flex;
    align-items: center;
    gap: 32px;
    border-bottom: 0.5px solid var(--border);
    background: rgba(0, 0, 0, 0.55);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }

  .brand-mark {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-mark-img {
    height: 28px;
    width: auto;
    display: block;
  }
  .brand-mark:hover .brand-mark-img {
    opacity: 0.85;
  }

  .nav-items {
    display: flex;
    gap: 26px;
    font-size: 14px;
    color: var(--text-3);
    margin-left: auto;
    align-items: center;
  }

  .nav-link {
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.2s;
    font-size: inherit;
  }
  .nav-link:hover {
    color: var(--text);
  }

  .active {
    color: var(--text);
    border-bottom: 1.5px solid var(--green);
    padding-bottom: 4px;
  }

  /* CTA cluster — separated visually from the nav links by a slightly larger gap */
  .nav-ctas {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-left: 8px;
  }

  .nav-support {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    text-decoration: none;
    border: 0.5px solid rgba(212,175,55,0.45);
    background: rgba(212,175,55,0.06);
    transition: background 0.15s, border-color 0.15s;
  }
  .nav-support:hover {
    background: rgba(212,175,55,0.14);
    border-color: rgba(212,175,55,0.7);
  }
  .nav-support svg {
    color: var(--gold);
  }

  @media (max-width: 1000px) {
    .nav { gap: 20px; }
    .nav-items { gap: 18px; }
    .nav-support { padding: 8px 12px; }
  }

  @media (max-width: 820px) {
    .nav { padding: 14px 20px; gap: 14px; flex-wrap: wrap; }
    .nav-items { font-size: 13px; gap: 14px; flex-wrap: wrap; }
    .nav-ctas { margin-left: 0; }
  }

  @media (max-width: 560px) {
    /* On very narrow screens, drop the "Support us" text to icon-only */
    .nav-support {
      gap: 0;
      padding: 8px 10px;
    }
  }
</style>