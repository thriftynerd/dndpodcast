---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<div class="ep-section">
  <div class="ep-section-eyebrow">What happened</div>
  <h2 class="ep-section-title">Show notes</h2>
  <div class="ep-notes">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>
</div>

<style>
  .ep-section { margin-bottom: 50px; }
  .ep-section-eyebrow { font-size: var(--t-small); letter-spacing: var(--ls-eyebrow); color: var(--green); font-weight: var(--fw-semibold); margin-bottom: 12px; text-transform: uppercase; }
  .ep-section-title { font-family: var(--font-display); font-size: var(--t-h2); font-weight: var(--fw-bold); line-height: var(--lh-tight); color: #f5f0e0; letter-spacing: var(--ls-display); margin-bottom: 22px; }

  .ep-notes p { font-size: var(--t-body); color: var(--text-2); line-height: var(--lh-relaxed); margin-bottom: 18px; }
  .ep-notes p:last-child { margin-bottom: 0; }
</style>