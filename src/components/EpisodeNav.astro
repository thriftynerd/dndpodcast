---
import type { EpisodeNavLink } from '../lib/rss';

interface Props {
  prev?: EpisodeNavLink;
  next?: EpisodeNavLink;
}
const { prev, next } = Astro.props;
---

<nav class="ep-nav">
  {prev ? (
    <a class="ep-nav-card prev" href={prev.href}>
      <div class="ep-nav-direction">← Previous</div>
      <div class="ep-nav-num">{prev.label}</div>
      <div class="ep-nav-title">{prev.title}</div>
    </a>
  ) : <div></div>}
  {next ? (
    <a class="ep-nav-card next" href={next.href}>
      <div class="ep-nav-direction">Next →</div>
      <div class="ep-nav-num">{next.label}</div>
      <div class="ep-nav-title">{next.title}</div>
    </a>
  ) : <div></div>}
</nav>

<style>
  .ep-nav { max-width: 1280px; margin: 0 auto; padding: 40px 40px 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .ep-nav-card { display: block; padding: 22px 26px; background: var(--surface); border: 0.5px solid var(--border); border-radius: 12px; transition: transform 0.2s, border-color 0.2s; cursor: pointer; text-decoration: none; }
  .ep-nav-card:hover { transform: translateY(-2px); border-color: rgba(151,196,89,0.3); }
  .ep-nav-direction { font-size: 11px; letter-spacing: 0.24em; color: var(--text-3); font-weight: 600; text-transform: uppercase; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .ep-nav-card.next .ep-nav-direction { justify-content: flex-end; }
  .ep-nav-num { font-family: "Cinzel", Georgia, serif; font-size: 13px; color: var(--gold); font-weight: 600; letter-spacing: 0.05em; margin-bottom: 4px; }
  .ep-nav-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: 22px; font-weight: 600; color: var(--text); line-height: 1.2; }
  .ep-nav-card.next { text-align: right; }

  @media (max-width: 900px) {
    .ep-nav { padding: 30px 24px 60px; grid-template-columns: 1fr; }
    .ep-nav-card.next { text-align: left; }
    .ep-nav-card.next .ep-nav-direction { justify-content: flex-start; }
  }
</style>