---
const PATREON_URL = 'https://patreon.com/dndpodcast';
---

<section class="patreon">
  <div class="patreon-inner">
    <div class="tankard-card">
      <div class="tankard-badge"><span class="tankard-badge-dot"></span>Patron exclusive</div>
      <div class="tankard-logo-wrap"><img class="tankard-logo" src="/images/image11_7d24a836.jpg" alt="Tales from the Foaming Tankard"/></div>
      <div class="tankard-desc">Like a whole second podcast. Side-quests with your favorite characters, and tavern tales from across Drunkeros. Available exclusively to patrons.</div>
      <div class="tankard-stat">
        <span class="tankard-stat-num">50+</span>
        <span class="tankard-stat-label">episodes in the archive</span>
      </div>
    </div>
    <div class="patreon-copy">
      <div class="patreon-eyebrow">Support the show</div>
      <h2 class="patreon-title">Please, our children are starving.</h2>
      <p class="patreon-sub">Greetings, Adventurers! is possible because of patrons. We have hours of exclusive shows, plus ad-free episodes, and a Discord with the cast, plus the warm feeling of keeping Drunkeros alive.</p>
      <div class="patreon-perks">
        <span class="patreon-perk">Tales from the Foaming Tankard</span>
        <span class="patreon-perk">Ad Free Episodes</span>
        <span class="patreon-perk">Monthly Outtakes</span>
        <span class="patreon-perk">Behind-the-scenes</span>
        <span class="patreon-perk">Patron Discord</span>
      </div>
      <div class="patreon-cta-side">
        <a class="patreon-cta-btn" href={PATREON_URL} target="_blank" rel="noopener">Become a patron <span style="opacity:0.7">→</span></a>
        <span class="patreon-stat">Tiers from $3/month. Cancel any time, no hard feelings.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .patreon { padding: 80px 40px; background: linear-gradient(135deg, #1a1408 0%, #251a0a 100%); border-top: 0.5px solid rgba(212,175,55,0.3); border-bottom: 0.5px solid rgba(212,175,55,0.3); position: relative; overflow: hidden; }
  .patreon-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr); gap: 50px; align-items: center; position: relative; z-index: 2; }
  .tankard-card { background: linear-gradient(160deg, #0d0808 0%, #150a05 100%); border-radius: 14px; border: 0.5px solid rgba(232,120,61,0.3); padding: 32px 30px; display: flex; flex-direction: column; gap: 22px; box-shadow: 0 24px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04); position: relative; overflow: hidden; }
  .tankard-card::before { content: ''; position: absolute; top: -50%; left: -10%; width: 70%; height: 70%; background: radial-gradient(ellipse, rgba(232,120,61,0.12) 0%, transparent 70%); pointer-events: none; }
  .tankard-badge { font-size: 11px; letter-spacing: 0.24em; color: #e8783d; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border: 0.5px solid rgba(232,120,61,0.4); border-radius: 999px; align-self: flex-start; background: rgba(232,120,61,0.08); position: relative; z-index: 2; }
  .tankard-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #e8783d; box-shadow: 0 0 8px rgba(232,120,61,0.7); }
  .tankard-logo-wrap { padding: 8px 0; position: relative; z-index: 2; }
  .tankard-logo { width: 100%; display: block; border-radius: 6px; }
  .tankard-desc { font-family: "Cormorant Garamond", Georgia, serif; font-size: 14.5px; color: #d8d2c5; line-height: 1.6; font-style: italic; position: relative; z-index: 2; }
  .tankard-stat { display: flex; align-items: baseline; gap: 12px; border-top: 0.5px solid rgba(255,255,255,0.08); padding-top: 18px; position: relative; z-index: 2; }
  .tankard-stat-num { font-family: "Cormorant Garamond", Georgia, serif; font-size: 36px; font-weight: 700; color: #e8783d; line-height: 1; letter-spacing: -0.02em; }
  .tankard-stat-label { font-size: 13px; color: var(--text-3); letter-spacing: 0.02em; }
  .patreon-copy { display: flex; flex-direction: column; }
  .patreon-eyebrow { font-size: 13px; letter-spacing: 0.28em; color: #d4af37; font-weight: 600; margin-bottom: 14px; }
  .patreon-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: clamp(2rem, 3.2vw, 2.7rem); font-weight: 700; line-height: 1.1; color: #f5f0e0; margin-bottom: 18px; }
  .patreon-sub { font-size: 16px; color: #d8d4c5; line-height: 1.6; margin-bottom: 24px; }
  .patreon-perks { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
  .patreon-perk { font-size: 13px; color: #e8c875; padding: 7px 14px; border-radius: 999px; background: rgba(212,175,55,0.08); border: 0.5px solid rgba(212,175,55,0.3); }
  .patreon-cta-side { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .patreon-cta-btn { background: #d4af37; color: #1a1408; padding: 16px 28px; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s; display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 6px 24px rgba(212,175,55,0.2); text-decoration: none; }
  .patreon-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 36px rgba(212,175,55,0.35); }
  .patreon-stat { font-size: 13px; color: rgba(212,175,55,0.65); font-style: italic; font-family: "Cormorant Garamond", Georgia, serif; }

  /* Font system overrides from mockup */
  .patreon-title { font-family: "Cinzel", Georgia, serif; letter-spacing: 0.005em; }
  .tankard-stat-num { font-family: "Cinzel", Georgia, serif; letter-spacing: 0.005em; }

  /* Readability pass overrides from mockup */
  .tankard-desc { font-style: normal; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; }
  .patreon-stat { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-weight: 500; color: rgba(212,175,55,0.85); }

  @media (max-width: 900px) {
    .patreon { padding: 50px 24px; }
    .patreon-inner { grid-template-columns: 1fr; gap: 30px; }
  }
</style>