---
import ShareButton from './ShareButton.astro';

interface Props {
  campaign: string;
  episodeNumber: string;
  title: string;
  description: string;
  artUrl: string;
  releaseDate: string;
  duration: string;
  season: string;
  dm: string;
}

const { campaign, episodeNumber, title, description, artUrl, releaseDate, duration, season, dm } = Astro.props;
---

<section class="ep-hero">
  <div class="ep-art-wrap">
    <div class="ep-art">
      <img src={artUrl} alt={`${title} cover art`} />
    </div>
  </div>
  <div class="ep-info">
    <div class="ep-num-prefix">{campaign} · Episode {episodeNumber}</div>
    <h1 class="ep-title">{title}</h1>
    <p class="ep-desc">{description}</p>
    <div class="ep-meta-row">
      <div class="ep-meta">
        <div class="ep-meta-lbl">Released</div>
        <div class="ep-meta-val">{releaseDate}</div>
      </div>
      <div class="ep-meta">
        <div class="ep-meta-lbl">Duration</div>
        <div class="ep-meta-val">{duration}</div>
      </div>
      <div class="ep-meta">
        <div class="ep-meta-lbl">Season</div>
        <div class="ep-meta-val">{season}</div>
      </div>
      <div class="ep-meta">
        <div class="ep-meta-lbl">DM</div>
        <div class="ep-meta-val">{dm}</div>
      </div>
    </div>
    <div class="ep-actions">
      <a class="btn-primary" href="#transcript">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Read transcript
      </a>
      <ShareButton />
    </div>
  </div>
</section>

<style>
  .ep-hero { padding: 32px 40px 50px; max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 360px) minmax(0, 1fr); gap: 50px; align-items: start; }
  .ep-art-wrap { position: relative; }
  .ep-art { width: 100%; aspect-ratio: 1; border-radius: 14px; overflow: hidden; box-shadow: 0 30px 70px rgba(0,0,0,0.5), 0 0 0 0.5px rgba(255,255,255,0.06); background: #1a1410; }
  .ep-art img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ep-info { display: flex; flex-direction: column; padding-top: 8px; }
  .ep-num-prefix { font-family: "Cinzel", Georgia, serif; font-size: 11px; letter-spacing: 0.2em; color: var(--gold); font-weight: 600; margin-bottom: 8px; }
  .ep-title { font-family: "Cinzel", Georgia, serif; font-size: clamp(2rem, 4vw, 3.4rem); line-height: 1; font-weight: 700; color: #f5f0e0; letter-spacing: 0.005em; margin-bottom: 18px; }
  .ep-desc { font-family: "Cormorant Garamond", Georgia, serif; font-size: 19px; color: var(--text-2); line-height: 1.55; font-weight: 500; max-width: 95%; margin-bottom: 28px; }
  .ep-meta-row { display: flex; gap: 22px; padding: 14px 0; border-top: 0.5px solid var(--border-2); border-bottom: 0.5px solid var(--border-2); margin-bottom: 28px; flex-wrap: wrap; }
  .ep-meta { display: flex; flex-direction: column; gap: 3px; }
  .ep-meta-lbl { font-size: 10px; letter-spacing: 0.2em; color: var(--text-4); font-weight: 600; text-transform: uppercase; }
  .ep-meta-val { font-size: 14px; color: var(--text); font-weight: 500; }
  .ep-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-primary { background: var(--green); color: #0a0f0c; padding: 12px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-flex; align-items: center; gap: 9px; cursor: pointer; transition: transform 0.15s; text-decoration: none; }
  .btn-primary:hover { transform: translateY(-1px); }
  .btn-secondary { background: var(--surface); color: var(--text); padding: 12px 22px; border-radius: 8px; font-size: 14px; font-weight: 500; border: 0.5px solid var(--border-2); display: inline-flex; align-items: center; gap: 9px; cursor: pointer; transition: background 0.2s; text-decoration: none; }
  .btn-secondary:hover { background: var(--surface-2); }

  @media (max-width: 900px) {
    .ep-hero { grid-template-columns: 1fr; padding: 24px 24px 40px; gap: 30px; }
    .ep-art-wrap { max-width: 320px; margin: 0 auto; }
  }
</style>