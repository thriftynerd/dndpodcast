---
interface Props {
  campaign?: 'all' | 'c1' | 'c2';
  title?: string;
}

const { campaign = 'all', title = 'Latest episodes' } = Astro.props;

const allEpisodes = [
  {
    art: 'https://geeklyinc.com/wp-content/uploads/2025/11/C2-163-079a-300x179.jpg',
    badge: 'C2 · Ep 182',
    campaign: 'c2',
    name: 'Big Bad Bread Wars',
    meta: '1h 24m · April 20, 2026',
  },
  {
    art: 'https://geeklyinc.com/wp-content/uploads/2026/04/C2-164-080a-300x179.jpg',
    badge: 'C2 · Ep 181',
    campaign: 'c2',
    name: 'Check Point Bing Bong',
    meta: '1h 18m · April 13, 2026',
  },
  {
    art: 'https://geeklyinc.com/wp-content/uploads/2024/11/C2-121-03d1-300x179.jpg',
    badge: 'C2 · Ep 180',
    campaign: 'c2',
    name: 'Super Rat Day',
    meta: '1h 32m · April 6, 2026',
  },
  {
    art: 'https://geeklyinc.com/wp-content/uploads/2026/03/178-banner-dedchicken-300x179.jpg',
    badge: 'C2 · Ep 179',
    campaign: 'c2',
    name: "Von Esper's Very Sad Wedding Day",
    meta: '1h 41m · March 30, 2026',
  },
];

const episodes = campaign === 'all'
  ? allEpisodes
  : allEpisodes.filter((ep) => ep.campaign === campaign);
---

<section class="sec">
  <div class="sec-inner">
    <div class="sec-hd">
      <div><div class="sec-eyebrow">Most recent</div><div class="sec-title">{title}</div></div>
      <div class="sec-link">Browse archive →</div>
    </div>
    <div class="eps">
      {episodes.map((ep) => (
        <div class="ep-card">
          <div class="ep-art">
            <img src={ep.art} alt="" />
            <div class="ep-num-badge">{ep.badge}</div>
            <div class="ep-play"><svg width="14" height="14" viewBox="0 0 12 12"><polygon points="3,2 3,10 10,6" fill="currentColor"/></svg></div>
          </div>
          <div class="ep-body">
            <div class="ep-name">{ep.name}</div>
            <div class="ep-meta">{ep.meta}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* same styles as before, unchanged */
  .sec { padding: 80px 40px; background: var(--bg); }
  .sec-inner { max-width: 1280px; margin: 0 auto; }
  .sec-hd { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px; gap: 20px; flex-wrap: wrap; }
  .sec-eyebrow { font-size: 13px; letter-spacing: 0.28em; color: var(--green); font-weight: 600; margin-bottom: 10px; }
  .sec-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 700; color: #f5f0e0; line-height: 1.05; }
  .sec-link { font-size: 14px; color: var(--text-3); }

  .eps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .ep-card { background: var(--surface); border-radius: 12px; overflow: hidden; border: 0.5px solid var(--border); cursor: pointer; transition: transform 0.2s, border-color 0.2s; }
  .ep-card:hover { transform: translateY(-3px); border-color: rgba(151,196,89,0.3); }
  .ep-art { width: 100%; aspect-ratio: 16/9; position: relative; overflow: hidden; background: var(--bg-2); }
  .ep-art img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
  .ep-card:hover .ep-art img { transform: scale(1.04); }
  .ep-num-badge { position: absolute; top: 14px; left: 14px; background: rgba(10,15,12,0.85); color: var(--green); padding: 5px 12px; border-radius: 5px; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; backdrop-filter: blur(4px); }
  .ep-play { position: absolute; bottom: 14px; right: 14px; width: 42px; height: 42px; border-radius: 50%; background: rgba(10,15,12,0.88); color: var(--green); display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .ep-body { padding: 20px 22px; }
  .ep-name { font-family: "Cormorant Garamond", Georgia, serif; font-size: 18px; font-weight: 700; color: var(--text); line-height: 1.3; margin-bottom: 8px; }
  .ep-meta { font-size: 13px; color: var(--text-3); }

  /* Font system override from mockup */
  .sec-title { font-family: "Cinzel", Georgia, serif; letter-spacing: 0.005em; }
  .ep-name { font-weight: 600; }

  @media (max-width: 900px) {
    .sec { padding: 50px 24px; }
    .eps { grid-template-columns: 1fr; }
  }
</style>