---
import type { ArchiveEpisode } from '../data/episodes-archive';
import { fmtDate } from '../data/episodes-archive';

interface RailCard {
  href: string;
  label: string;
  note: string;
}

interface Props {
  recent: ArchiveEpisode[];      // top 8 from data, sorted newest-first
  startHere: RailCard[];
  loreLandmarks: RailCard[];
}

const { recent, startHere, loreLandmarks } = Astro.props;
---

<div id="curated-rails-wrapper">
  <section class="rails">
    <div class="rail recent-rail">
      <div class="rail-header">
        <div class="rail-eyebrow">Just Released</div>
        <div class="rail-title">Recent episodes</div>
      </div>
      <div class="rail-grid">
        {recent.map((ep) => {
          const badge = ep.kind === 'bonus' ? 'Bonus' : ep.episodeNumber ? `${ep.kind === 'c2' ? 'C2' : 'C1'} · Ep ${ep.episodeNumber}` : ep.kind.toUpperCase();
          return (
            <a class="recent-card" href={`/episodes/${ep.slug}`}>
              <div class="recent-art">
                {ep.artUrl ? <img src={ep.artUrl} alt="" /> : <div class="recent-art-placeholder">{ep.kind.toUpperCase()}</div>}
                <div class="recent-badge">{badge}</div>
              </div>
              <div class="recent-body">
                <h3 class="recent-title">{ep.title}</h3>
                <div class="recent-meta">{ep.duration} · {fmtDate(ep.date)}</div>
                <p class="recent-summary">{ep.description.length > 140 ? ep.description.slice(0, 140) + '...' : ep.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <div class="rail">
      <div class="rail-header">
        <div class="rail-eyebrow">For New Adventurers</div>
        <div class="rail-title">Start here</div>
      </div>
      <div class="rail-grid">
        {startHere.map((card) => (
          <a class="rail-card" href={card.href}>
            <div class="rail-card-label">{card.label}</div>
            <div class="rail-card-note">{card.note}</div>
            <div class="rail-card-arrow">→</div>
          </a>
        ))}
      </div>
    </div>

    <div class="rail">
      <div class="rail-header">
        <div class="rail-eyebrow">Defining Moments</div>
        <div class="rail-title">Lore landmarks</div>
      </div>
      <div class="rail-grid">
        {loreLandmarks.map((card) => (
          <a class="rail-card" href={card.href}>
            <div class="rail-card-label">{card.label}</div>
            <div class="rail-card-note">{card.note}</div>
            <div class="rail-card-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"><div class="section-divider-inner"></div></div>
</div>

<style>
  .rails { max-width: 1280px; margin: 0 auto; padding: 60px 40px 30px; display: flex; flex-direction: column; gap: 60px; }
  .rail-header { margin-bottom: 22px; }
  .rail-eyebrow { font-size: 12px; letter-spacing: 0.28em; color: var(--green); font-weight: 600; margin-bottom: 10px; }
  .rail-title { font-family: "Cinzel", Georgia, serif; font-size: clamp(1.5rem, 2.4vw, 2rem); font-weight: 700; line-height: 1.1; color: #f5f0e0; letter-spacing: 0.005em; }

  /* Recent rail: image cards */
  .recent-rail .rail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; }
  .recent-card { background: var(--surface); border: 0.5px solid var(--border); border-radius: 12px; overflow: hidden; transition: transform 0.2s, border-color 0.2s; text-decoration: none; display: flex; flex-direction: column; }
  .recent-card:hover { transform: translateY(-3px); border-color: rgba(151,196,89,0.3); }
  .recent-art { aspect-ratio: 16/9; background: var(--bg-2); position: relative; overflow: hidden; }
  .recent-art img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .recent-art-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: "Cinzel", Georgia, serif; color: var(--text-4); font-size: 28px; font-weight: 700; letter-spacing: 0.08em; }
  .recent-badge { position: absolute; top: 12px; left: 12px; background: rgba(10,15,12,0.88); color: var(--green); padding: 5px 10px; border-radius: 4px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; backdrop-filter: blur(4px); }
  .recent-body { padding: 16px 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .recent-title { font-family: "Cormorant Garamond", Georgia, serif; font-size: 17px; font-weight: 600; color: var(--text); line-height: 1.3; }
  .recent-meta { font-size: 12px; color: var(--text-3); }
  .recent-summary { font-size: 13.5px; color: var(--text-2); line-height: 1.5; margin: 0; }

  /* Other rails: text cards */
  .rail:not(.recent-rail) .rail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
  .rail-card { padding: 22px 24px; background: var(--surface); border: 0.5px solid var(--border); border-radius: 12px; text-decoration: none; transition: transform 0.2s, border-color 0.2s; display: flex; flex-direction: column; gap: 6px; position: relative; }
  .rail-card:hover { transform: translateY(-2px); border-color: rgba(151,196,89,0.3); }
  .rail-card-label { font-family: "Cormorant Garamond", Georgia, serif; font-size: 19px; font-weight: 600; color: var(--text); line-height: 1.2; }
  .rail-card-note { font-size: 13px; color: var(--text-3); line-height: 1.5; }
  .rail-card-arrow { color: var(--green); margin-top: 8px; font-size: 16px; }

  .section-divider { padding: 30px 40px; max-width: 1280px; margin: 0 auto; }
  .section-divider-inner { height: 1px; background: var(--border); }

  @media (max-width: 900px) {
    .rails { padding: 40px 24px 20px; gap: 40px; }
    .recent-rail .rail-grid,
    .rail:not(.recent-rail) .rail-grid { grid-template-columns: 1fr; }
    .section-divider { padding: 20px 24px; }
  }
</style>