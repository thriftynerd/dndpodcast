<style>
  .tw-section {
    scroll-margin-top: 76px;
    padding: 50px 40px;
    background: linear-gradient(180deg, var(--bg-2), var(--bg));
  }
  .tw-card {
    max-width: 1280px;
    margin: 0 auto;
    background: linear-gradient(135deg, #1c0d3d 0%, #2d1561 50%, #1f0a4a 100%);
    border-radius: 14px;
    border: 0.5px solid rgba(145,70,255,0.4);
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    box-shadow: 0 24px 60px rgba(0,0,0,0.4), 0 0 0 1px rgba(145,70,255,0.1) inset;
    position: relative;
  }
  .tw-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, rgba(145,70,255,0.25) 0%, transparent 50%);
    pointer-events: none;
  }

  .tw-embed-wrap {
    position: relative;
    background: #000;
    display: flex;
    align-items: stretch;
    min-height: 340px;
  }
  .tw-embed-wrap iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .tw-content {
    position: relative;
    z-index: 2;
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
  }
  .tw-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: #ff9090;
    font-weight: 600;
    text-transform: uppercase;
  }
  .tw-eyebrow-pulse {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #ff5757;
    box-shadow: 0 0 12px rgba(255,87,87,0.8);
    animation: pulse 2.4s infinite;
  }
  .tw-headline {
    font-family: "Cinzel", Georgia, serif;
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    letter-spacing: 0.005em;
    margin: 0;
  }
  .tw-sub {
    font-size: 14.5px;
    color: #d8c8ff;
    line-height: 1.6;
    margin: 0;
  }
  .tw-sub a {
    color: #fff;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.4);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .tw-sub a:hover {
    text-decoration-color: #fff;
  }

  .tw-coupon {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border: 1px dashed rgba(255,255,255,0.45);
    border-radius: 5px;
    background: rgba(255,255,255,0.06);
    align-self: flex-start;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    margin-top: 4px;
    font-family: inherit;
    color: #fff;
  }
  .tw-coupon:hover {
    background: rgba(255,255,255,0.14);
    border-color: #fff;
  }
  .tw-coupon-label {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: 9.5px;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.65);
    font-weight: 600;
    text-transform: uppercase;
  }
  .tw-coupon-code {
    font-family: "Courier New", monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #fff;
  }
  .tw-coupon-discount {
    font-size: 12px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }
  .tw-coupon-toast {
    position: absolute;
    top: -32px;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    color: #5c16c5;
    padding: 6px 12px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  .tw-coupon.copied .tw-coupon-toast {
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }

  .tw-actions {
    display: flex;
    gap: 10px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .tw-cta {
    background: #fff;
    color: #5c16c5;
    padding: 12px 22px;
    border-radius: 7px;
    font-size: 14px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    cursor: pointer;
    transition: transform 0.15s;
    text-decoration: none;
  }
  .tw-cta:hover {
    transform: translateY(-2px);
  }
  .tw-cta-2 {
    background: rgba(255,255,255,0.08);
    color: #fff;
    padding: 12px 22px;
    border-radius: 7px;
    border: 0.5px solid rgba(255,255,255,0.3);
    font-size: 14px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
  }
  .tw-cta-2:hover {
    background: rgba(255,255,255,0.14);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 900px) {
    .tw-section { padding: 30px 20px; }
    .tw-card { grid-template-columns: 1fr; }
    .tw-embed-wrap { min-height: 0; aspect-ratio: 16/9; }
    .tw-content { padding: 28px 24px; }
  }
</style>

<script>
  document.querySelectorAll('.tw-coupon').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      navigator.clipboard.writeText(code).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1600);
      }).catch(() => {
        window.open('https://www.dieharddice.com/products/7-piece-rpg-set-drakona-arita-for-greetings-adventurers', '_blank');
      });
    });
  });
</script>