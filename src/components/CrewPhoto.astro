---
interface Props {
  src: string;
  alt: string;
  caption: string;
  captionSub?: string;
}

const { src, alt, caption, captionSub } = Astro.props;
---

<section class="crew">
  <div class="crew-inner">
    <div class="crew-photo">
      <img src={src} alt={alt} />
      <div class="crew-photo-overlay">
        <div>
          <div class="crew-caption">{caption}</div>
          {captionSub && <div class="crew-caption-sub">{captionSub}</div>}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .crew { padding: 70px 40px 0; background: var(--bg); }
  .crew-inner { max-width: 1280px; margin: 0 auto; }
  .crew-photo { width: 100%; aspect-ratio: 1.6; border-radius: 14px; overflow: hidden; position: relative; box-shadow: 0 30px 80px rgba(0,0,0,0.5); border: 0.5px solid rgba(255,255,255,0.08); }
  .crew-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .crew-photo-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(10,15,12,0.85) 100%); display: flex; align-items: flex-end; padding: 28px 32px; }
  .crew-caption { font-family: var(--font-editorial); font-size: var(--t-h4); font-style: italic; color: #f0ebe0; }
  .crew-caption-sub { font-size: var(--t-small); color: var(--text-3); margin-top: 4px; font-style: normal; letter-spacing: 0.04em; }

  /* Readability pass override from mockup */
  .crew-caption-sub { font-family: var(--font-sans); font-style: normal; font-weight: var(--fw-medium); color: var(--text-2); }

  @media (max-width: 900px) {
    .crew { padding: 40px 24px 0; }
    .crew-photo { aspect-ratio: 1.3; }
    .crew-photo-overlay { padding: 20px; }
  }
</style>