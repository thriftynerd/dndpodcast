---
import type { MentionItem } from '../lib/rss';

const PATREON_URL = 'https://patreon.com/dndpodcast';

interface Props {
  mentions: MentionItem[];
}
const { mentions } = Astro.props;
---

<aside class="ep-sidebar">
  {mentions.length > 0 && (
    <div class="side-block">
      <div class="side-eyebrow">Mentioned</div>
      <ul class="mention-list">
        {mentions.map((m) => (
          <li class="mention-item">
            <span class={`mention-tag mention-${m.type}`}>{m.type}</span>
            <a class="mention-name" href={m.href}>{m.name}</a>
            <span class="mention-note">{m.note}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
  <div class="side-block new-listener">
    <div class="side-eyebrow" style="color: var(--gold);">New listener?</div>
    <div class="side-title">600+ episodes is a lot.</div>
    <div class="side-body">Don't try to start with episode 182. We promise it doesn't help. Try our hand-picked entry points.</div>
    <a class="new-listener-cta" href="/begin">Begin your adventure →</a>
  </div>
  <div class="side-block">
    <div class="side-eyebrow">Support the show</div>
    <div class="side-title">Become a patron</div>
    <div class="side-body">Tales from the Foaming Tankard, ad-free episodes, monthly outtakes, patron Discord. Tiers from $3/month.</div>
    <a class="new-listener-cta" style="color: var(--green);" href={PATREON_URL} target="_blank" rel="noopener">Join the Patreon →</a>
  </div>
</aside>

<style>
  .ep-sidebar { position: sticky; top: 220px; }

  .side-block { background: var(--surface); border: 0.5px solid var(--border); border-radius: 12px; padding: 22px 24px; margin-bottom: 18px; }
  .side-block:last-child { margin-bottom: 0; }
  .side-eyebrow { font-size: var(--t-small); letter-spacing: var(--ls-eyebrow); color: var(--green); font-weight: var(--fw-semibold); text-transform: uppercase; margin-bottom: 14px; }
  .side-title { font-family: var(--font-editorial); font-size: var(--t-h4); font-weight: var(--fw-semibold); color: var(--text); margin-bottom: 14px; letter-spacing: var(--ls-tight); }
  .side-body { font-size: var(--t-body-sm); color: var(--text-2); line-height: var(--lh-normal); }

  .mention-list { list-style: none; padding: 0; margin: 0; }
  .mention-item { padding: 11px 0; border-top: 0.5px solid rgba(255,255,255,0.04); display: grid; grid-template-columns: 70px minmax(0, 1fr); gap: 12px; align-items: baseline; }
  .mention-item:first-child { border-top: none; padding-top: 4px; }
  .mention-tag { font-size: var(--t-tiny); letter-spacing: var(--ls-eyebrow); font-weight: var(--fw-semibold); text-transform: uppercase; padding: 3px 8px; border-radius: 4px; text-align: center; }
  .mention-character { background: rgba(151,196,89,0.12); color: var(--green); }
  .mention-location { background: rgba(212,175,55,0.12); color: var(--gold); }
  .mention-faction { background: rgba(211,90,90,0.12); color: #d35a5a; }
  .mention-event { background: rgba(168,127,199,0.14); color: #c5a5d6; }
  .mention-item { font-size: var(--t-small); }
  .mention-name { font-size: var(--t-body-sm); color: var(--text); font-weight: var(--fw-medium); transition: color 0.2s; cursor: pointer; }
  .mention-name:hover { color: var(--green); }
  .mention-note { display: block; grid-column: 2; font-size: var(--t-tiny); color: var(--text-3); margin-top: 2px; }

  .new-listener { background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(151,196,89,0.04)); border-color: rgba(212,175,55,0.25); }
  .new-listener-cta { display: inline-block; margin-top: 10px; font-size: var(--t-small); color: var(--gold); font-weight: var(--fw-semibold); text-decoration: none; }

  @media (max-width: 1024px) {
    .ep-sidebar { position: static; }
  }
</style>